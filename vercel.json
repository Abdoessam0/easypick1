{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "corepack enable && corepack pnpm install --frozen-lockfile",
  "buildCommand": "corepack pnpm --filter @workspace/easypick build",
  "devCommand": "corepack pnpm --filter @workspace/easypick dev",
  "outputDirectory": "artifacts/easypick/dist/public",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
